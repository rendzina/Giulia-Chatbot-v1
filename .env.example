# Copy to .env and fill in values. Never commit .env.
# (Created 24-04-2026)

MISTRAL_API_KEY=

# Default matches mongodb_docker (no auth, local dev)
MONGODB_URI=mongodb://127.0.0.1:27017/giulia

# Embeddings and chat (Mistral API; same platform as "Le Chat", programmatic access)
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-small-latest

# Retrieval
RAG_TOP_K=8
